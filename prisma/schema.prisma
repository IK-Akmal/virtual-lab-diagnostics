generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  passwordHash String
  createdAt    DateTime        @default(now())
  progress     TopicProgress[]
  testResults  TestResult[]
  taskAnswers  TaskAnswer[]
}

model TopicProgress {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, topicId])
}

model TestResult {
  id             String   @id @default(cuid())
  userId         String
  topicId        String
  score          Int
  totalQuestions  Int
  answers        String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
}

model TaskAnswer {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  taskId    String
  answer    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
